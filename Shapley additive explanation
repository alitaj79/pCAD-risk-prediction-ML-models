# Ensure shapviz is up‑to‑date (needed for return_ggplot)
# install.packages("shapviz")

library(shapviz)
library(ggplot2)

dir.create("waterfall_plots", showWarnings = FALSE)

for (case_name in names(case_ids)) {
  
  row_id <- case_ids[case_name]
  
  # Create the waterfall plot as a ggplot object
  p <- sv_waterfall(
    shp,
    row_id = row_id,
    max_display = 8,
    size = 4,
    fill_colors = c("#1B9E77", "#D95F02"),
    return_ggplot = TRUE               # <-- this is the key
  )
  
  # Optionally add a descriptive title
  p <- p + labs(
    title = paste0("SHAP Waterfall – ", case_name),
    subtitle = paste0("Predicted probability: ", round(pred_yes[row_id], 3))
  )
  
  # Save with ggsave
  ggsave(
    filename = paste0("waterfall_plots/", gsub(" ", "_", case_name), ".tiff"),
    plot = p,
    width = 7,
    height = 5,
    dpi = 400
  )
}
